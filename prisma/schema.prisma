generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
model User {
  id            Int            @id @default(autoincrement())
  username      String         @unique
  email         String?        @unique
  password      String
  name          String
  firstName     String   @default("") @map("first_name")
  lastName      String   @default("") @map("last_name")
  middleName    String?  @map("middle_name")
  age           Int?
  role          String         @default("guest")
  isActive      Boolean        @default(true) @map("is_active")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  
  // Enhanced Profile Fields (Analytics Module)
  barangay              String?
  school                String?
  schoolOther           String?  @map("school_other") // For "Other (specify)" option
  occupation            String?
  occupationOther       String?  @map("occupation_other") // For "Other (specify)" option
  gender                String?
  gradeLevel            String?  @map("grade_level") // For kids/students
  
  // Assessment Scores
  preTestScore          Int?     @map("pre_test_score")
  postTestScore         Int?     @map("post_test_score")
  preTestCompletedAt    DateTime? @map("pre_test_completed_at")
  postTestCompletedAt   DateTime? @map("post_test_completed_at")
  
  // Engagement Tracking
  engagementPoints      Int      @default(0) @map("engagement_points")
  totalTimeSpentMinutes Int      @default(0) @map("total_time_spent_minutes")
  lastActiveAt          DateTime @default(now()) @map("last_active_at")
  
  // Data Privacy & Profile Status
  dataPrivacyConsent    Boolean  @default(false) @map("data_privacy_consent")
  profileCompleted      Boolean  @default(false) @map("profile_completed")

  // Laravel token field
  rememberToken         String?  @map("remember_token")
  
  blogPosts             BlogPost[]
  progress              UserProgress[]
  quizResults           QuizResult[]
  notifications         Notification[]
  safeScapeProgress     SafeScapeProgress[]
  assessmentAnswers     UserAnswer[]
  engagementLogs        EngagementLog[]
  floorPlans            FloorPlan[]
  simulationJobs        SimulationJob[]

  @@map("users")
}

model QuickQuestion {
  id           Int                   @id @default(autoincrement())
  category     String
  questionText String                @map("question_text")
  responseText String                @map("response_text")
  order        Int                   @default(0)
  isActive     Boolean               @default(true) @map("is_active")
  createdAt    DateTime              @default(now()) @map("created_at")
  updatedAt    DateTime              @updatedAt @map("updated_at")

  @@map("quick_questions")
}

model BlogPost {
  id          Int             @id @default(autoincrement())
  title       String
  excerpt     String
  content     String
  imageUrl    String?         @map("image_url")
  category    String
  authorId    Int             @map("author_id")
  isPublished Boolean         @default(true) @map("is_published")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  author      User            @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([category])
  @@index([authorId])
  @@map("blog_posts")
}

model Video {
  id          Int             @id @default(autoincrement())
  title       String
  description String?
  youtubeId   String          @map("youtube_id")
  category    String
  duration    String?
  isActive    Boolean         @default(true) @map("is_active")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  @@map("videos")
}

model KidsModule {
  id          Int            @id @default(autoincrement())
  title       String
  description String?
  dayNumber   Int            @unique @map("day_number")
  content     String
  isActive    Boolean        @default(true) @map("is_active")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  progress    UserProgress[]

  @@map("kids_modules")
}

model UserProgress {
  id          Int        @id @default(autoincrement())
  userId      Int        @map("user_id")
  moduleId    Int        @map("module_id")
  completed   Boolean    @default(false)
  score       Int        @default(0)
  completedAt DateTime?  @map("completed_at")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  module      KidsModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleId])
  @@map("user_progress")
}

model QuizResult {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  quizType    String   @map("quiz_type")
  score       Int      @default(0)
  maxScore    Int      @default(0) @map("max_score")
  completedAt DateTime @default(now()) @map("completed_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("quiz_results")
}

// Enum values stored as varchar strings in the database (Laravel convention)
// UserRole: "guest", "kid", "adult", "professional", "admin"
// ContentCategory: "kids", "adult", "professional"
// QuickQuestionCategory: "emergency", "prevention", "equipment", "general"

model Notification {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id") // User who receives the notification
  title       String
  message     String
  type        String   // 'blog', 'video', 'system', etc.
  category    String   // 'adult', 'professional', 'kids'
  isRead      Boolean  @default(false) @map("is_read")
  createdAt   DateTime @default(now()) @map("created_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications_custom")
}

model FireCodeSection {
  id            Int     @id @default(autoincrement())
  title         String
  sectionNum    String  @map("section_num")
  content       String
  parentSectionId Int?  @map("parent_section_id")
  order         Int
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  parentSection FireCodeSection? @relation(fields: [parentSectionId], references: [id], onDelete: Cascade, name: "ParentSubSection")
  subSections   FireCodeSection[] @relation(name: "ParentSubSection")

  @@map("fire_code_sections")
}

model CarouselImage {
  id        Int      @id @default(autoincrement())
  title     String
  altText   String?  @map("alt_text")
  imageUrl  String   @map("image_url")
  order     Int      @default(0)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("carousel_images")
}

model SafeScapeProgress {
  id          Int       @id @default(autoincrement())
  userId      Int       @map("user_id")
  moduleNum   Int       @map("module_num") // 1-5 for the 5 SafeScape modules
  sectionData String    @map("section_data") // JSON string storing section completion status
  completed   Boolean   @default(false)
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleNum])
  @@map("safescape_progress")
}

// ============================================
// ENHANCED ANALYTICS & ASSESSMENT MODELS
// ============================================

model AssessmentQuestion {
  id              Int            @id @default(autoincrement())
  question        String
  options         Json           // Array of 4 options: string[]
  correctAnswer   Int            @map("correct_answer") // Index of correct answer (0-3)
  explanation     String
  category        String         // From ASSESSMENT_CATEGORIES
  difficulty      String         @default("Medium") // Easy, Medium, Hard
  isActive        Boolean        @default(true) @map("is_active")
  forRoles        Json           @map("for_roles") // ["kid", "adult", "professional"]
  type            String         @default("preTest") // "preTest", "postTest", "quiz"
  order           Int            @default(0)
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  userAnswers     UserAnswer[]

  @@map("assessment_questions")
}

model UserAnswer {
  id             Int                 @id @default(autoincrement())
  userId         Int                 @map("user_id")
  questionId     Int                 @map("question_id")
  selectedAnswer Int                 @map("selected_answer") // Index of selected answer (0-3)
  isCorrect      Boolean             @map("is_correct")
  testType       String              @map("test_type") // "preTest" or "postTest"
  answeredAt     DateTime            @default(now()) @map("answered_at")
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  question       AssessmentQuestion  @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([questionId])
  @@map("user_answers")
}

model EngagementLog {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  eventType   String   @map("event_type") // "quiz", "game", "video", "module", "login", "preTest", "postTest"
  eventData   Json?    @map("event_data") // Additional data: { quizType, score, duration, etc }
  points      Int      @default(0)
  loggedAt    DateTime @default(now()) @map("logged_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, loggedAt])
  @@map("engagement_logs")
}

model AnalyticsCache {
  id          Int      @id @default(autoincrement())
  cacheKey    String   @unique @map("cache_key")
  cacheData   Json     @map("cache_data")
  expiresAt   DateTime @map("expires_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([cacheKey, expiresAt])
  @@map("analytics_cache")
}

// Floor Plan Library for Simulation
model FloorPlan {
  id              Int         @id @default(autoincrement())
  name            String
  description     String?
  gridData        Json        @map("grid_data") // The 256x256 grid as JSON array
  thumbnail       String?     // Base64 thumbnail image
  originalImage   String?     @map("original_image") // Base64 original floor plan image
  
  // Ownership & Visibility
  userId          Int         @map("user_id")
  uploaderName    String      @map("uploader_name") // Denormalized for display
  isPublic        Boolean     @default(false) @map("is_public")
  
  // Clone tracking (like git)
  clonedFromId    Int?        @map("cloned_from_id") // ID of parent floor plan if cloned
  clonedFrom      FloorPlan?  @relation("FloorPlanClones", fields: [clonedFromId], references: [id])
  clones          FloorPlan[] @relation("FloorPlanClones")
  
  // Metadata
  gridWidth       Int         @default(256) @map("grid_width")
  gridHeight      Int         @default(256) @map("grid_height")
  exitCount       Int         @default(0) @map("exit_count")
  
  // Processing info
  processingMethod String     @default("unet") @map("processing_method") // "unet", "gemini", "manual"
  threshold        Float?     // U-Net threshold used
  invertMask       Boolean?   @map("invert_mask") // Whether mask was inverted
  
  // Timestamps
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  
  // Relations
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isPublic])
  @@index([clonedFromId])
  @@map("floor_plans")
}

// Simulation Job Tracking (migrated from SQLite)
model SimulationJob {
  id            String   @id @default(uuid())
  status        String   @default("queued")  // queued, processing, complete, failed
  result        Json?
  error         String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  
  // Link to user who started the simulation (optional)
  userId        Int?     @map("user_id")
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  // Store configuration for debugging
  config        Json?

  @@index([status])
  @@index([userId])
  @@index([createdAt])
  @@map("simulation_jobs")
}