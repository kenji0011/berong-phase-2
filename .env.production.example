# ===========================================
# BFP Berong SafeScape - Production Environment
# ===========================================
# Copy this file to .env on your production server
# Generate secrets with: openssl rand -base64 32
# NEVER commit the actual .env file to git!

# ===========================================
# Domain Configuration
# ===========================================
DOMAIN=bfpscberong.app

# ===========================================
# Database Configuration (PostgreSQL)
# ===========================================
POSTGRES_USER=bfp_prod_user
POSTGRES_PASSWORD=CHANGE_ME_USE_openssl_rand_base64_32
POSTGRES_DB=bfp_berong

# ===========================================
# Authentication (REQUIRED - must change!)
# ===========================================
# Generate with: openssl rand -base64 32
JWT_SECRET=CHANGE_ME_USE_openssl_rand_base64_32

# ===========================================
# Backend Configuration
# ===========================================
# Internal Docker network URL (do NOT change)
BACKEND_URL=http://python-backend:8000

# ===========================================
# CORS Origins
# ===========================================
CORS_ORIGINS=https://bfpscberong.app,https://www.bfpscberong.app,http://nextjs:3000

# ===========================================
# AI Features (Google Gemini - optional)
# ===========================================
# Get your API key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ===========================================
# Email Notifications (optional)
# ===========================================
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
